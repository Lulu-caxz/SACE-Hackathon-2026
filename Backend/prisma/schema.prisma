generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

enum Role {
  INSPETOR  
  DIRECAO
  SECRETARIA
  NUTRICIONISTA
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
}

enum TipoRefeicao {
  CAFE_MANHA
  ALMOCO
  CAFE_TARDE
  JANTA
  REFEICAO_E_LANCHE
}

enum FaixaEtaria {
  CRECHE_0_A_3
  INFANTIL_4_A_5
  FUNDAMENTAL_6_A_10
  FUNDAMENTAL_11_A_15
  EJA
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
  AJUSTE
}

model Escola {
  id         String @id @default(uuid())
  nome       String
  bairro     String
  endereco   String
  email      String
  telefone   String
  diretor    String
  supervisor String

  usuarios   Usuario[]
  estoque    Estoque?

  @@map("escolas")
}

model Usuario {
  id                String             @id @default(uuid())
  role              Role
  nome              String
  email             String             @unique
  password          String
  cpf               String             @unique @db.VarChar(11)

  escolaId          String?
  escola            Escola?            @relation(fields: [escolaId], references: [id])
  registrosInspecao RegistroInspecao[]
  notificacoes      Notificacao[]

  @@map("usuarios")
}

model ReferenciaNutricional {
  id          String      @id @default(uuid())
  faixaEtaria FaixaEtaria @unique
  dieta       String      @default("DIETA GERAL")
  kcalAlvo    Float
  choMin      Float
  choMax      Float
  ptnMin      Float
  ptnMax      Float
  lipMin      Float
  lipMax      Float
  sodioMaxMg  Float

  @@map("referencias_nutricionais")
}

model CardapioSemanal {
  id               String                  @id @default(uuid())
  dataInicial      DateTime                @db.Date
  dataFinal        DateTime                @db.Date
  mes              Int
  ano              Int
  criadoEm         DateTime                @default(now())
  atualizadoEm     DateTime                @updatedAt
  status           String                  @default("PENDENTE")
  motivoReprovacao String?                 @db.Text

  dias             CardapioDia[]
  notificacoes     Notificacao[]
  nutricionais     InformacaoNutricional[] // ⚡ VÍNCULO ADICIONADO AQUI!

  @@map("cardapios_semanais")
}

model CardapioDia {
  id         String            @id @default(uuid())
  cardapioId String
  cardapio   CardapioSemanal   @relation(fields: [cardapioId], references: [id], onDelete: Cascade)
  data       DateTime          @db.Date
  dia        DiaSemana

  refeicoes  Refeicao[]
  registro   RegistroInspecao?

  @@map("cardapios_dias")
}

model Refeicao {
  id            String                  @id @default(uuid())
  cardapioDiaId String
  cardapioDia   CardapioDia             @relation(fields: [cardapioDiaId], references: [id], onDelete: Cascade)
  tipo          String
  descricao     String                  @db.Text

  nutricionais  InformacaoNutricional[]

  @@map("refeicoes")
}

model InformacaoNutricional {
  id            String           @id @default(uuid())
  refeicaoId    String?
  refeicao      Refeicao?        @relation(fields: [refeicaoId], references: [id], onDelete: Cascade)
  cardapioId    String?          // ⚡ VÍNCULO COM O CARDÁPIO ADICIONADO AQUI!
  cardapio      CardapioSemanal? @relation(fields: [cardapioId], references: [id], onDelete: Cascade)
  diaAbrev      String?
  faixaEtaria   FaixaEtaria?
  dieta         String           @default("DIETA GERAL")
  kcal          Float
  cho           Float
  ptn           Float
  lip           Float
  sodioMg       Float
  observacoes   String?

  @@map("informacoes_nutricionais")
}

model Notificacao {
  id         String          @id @default(uuid())
  usuarioId  String?
  usuario    Usuario?        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cardapioId String
  cardapio   CardapioSemanal @relation(fields: [cardapioId], references: [id], onDelete: Cascade)
  titulo     String
  mensagem   String          @db.Text
  lida       Boolean         @default(false)
  criadoEm   DateTime        @default(now())

  @@map("notificacoes")
}

model RegistroInspecao {
  id              String      @id @default(uuid())
  cardapioDiaId   String      @unique
  cardapioDia     CardapioDia @relation(fields: [cardapioDiaId], references: [id], onDelete: Cascade)
  inspetoraId     String
  inspetora       Usuario     @relation(fields: [inspetoraId], references: [id])
  data            DateTime    @db.Date
  alunosPresentes Int
  pratosServidos  Int
  comidaFeitaKg   Float
  sobraKg         Float
  observacoes     String?
  criadoEm        DateTime    @default(now())

  @@map("registros_inspecao")
}

model Estoque {
  id            String                @id @default(uuid())
  escolaId      String                @unique
  escola        Escola                @relation(fields: [escolaId], references: [id], onDelete: Cascade)
  itens         ItemEstoque[]
  criadoEm      DateTime              @default(now())
  atualizadoEm  DateTime              @updatedAt
  movimentacoes MovimentacaoEstoque[]

  @@map("estoques")
}

model Produto {
  id    String        @id @default(uuid())
  nome  String
  marca String?
  itens ItemEstoque[]

  @@map("produtos")
}

model ItemEstoque {
  id            String                @id @default(uuid())
  estoqueId     String
  estoque       Estoque               @relation(fields: [estoqueId], references: [id], onDelete: Cascade)
  produtoId     String
  produto       Produto               @relation(fields: [produtoId], references: [id])
  lote          String
  validade      DateTime
  quantidade    Float
  unidade       String                @default("kg")
  criadoEm      DateTime              @default(now())
  atualizadoEm  DateTime              @updatedAt
  movimentacoes MovimentacaoEstoque[]

  @@map("itens_estoque")
}

model MovimentacaoEstoque {
  id         String           @id @default(uuid())
  estoqueId  String
  estoque    Estoque          @relation(fields: [estoqueId], references: [id], onDelete: Cascade)
  itemId     String
  item       ItemEstoque      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tipo       TipoMovimentacao
  quantidade Float
  motivo     String?
  criadoEm   DateTime         @default(now())

  @@map("movimentacoes_estoque")
}